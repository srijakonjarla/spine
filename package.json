{
  "name": "spine",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web": "npm --workspace apps/web run dev",
    "mobile": "npm --workspace apps/mobile run start",
    "mobile:ios": "npm --workspace apps/mobile run ios",
    "web:build": "npm --workspace apps/web run build",
    "lint": "npm --workspace apps/mobile run lint",
    "lint:fix": "npm --workspace apps/mobile run lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
